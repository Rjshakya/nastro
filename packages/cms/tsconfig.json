{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    // "skipLibCheck": true,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@/*": ["./src/*"]
    },
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./",
    "outDir": "./dist",
    "types": ["@types/node"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist", // Stop TSC from looking inside the output folder
    "node_modules"
  ]
}

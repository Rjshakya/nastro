      "type": "code",
      "content": {
        "code": "namespace function_declaration_demo_1 {\n\n\tconsole.log(greetNamed(\"John\")); // OK\n\tconsole.log(greetUnnamed(\"John\")); // Error\n\t\n\tfunction greetNamed(name: string): string {\n\t    return `Hi! ${name}`;\n\t}\n\t\n\tlet greetUnnamed = function(name: string): string {\n\t    return `Hi! ${name}`;\n\t};\n\t\n}",
        "language": "typescript",

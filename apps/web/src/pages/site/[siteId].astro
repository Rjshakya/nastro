---
import MainLayout from "@/layouts/main.astro";
import { Protected } from "@/layouts/protected";
import SiteEditorDashboard from "@/components/site/editor";
export const prerender = false;
const siteId = Astro.params?.siteId as string;
const pageId = Astro.url.searchParams.get("pageId") ?? "";
---

<MainLayout content="Site Editor">
  <Protected client:load>
    <SiteEditorDashboard
      client:load
      transition:persist
      pageId={pageId}
      siteId={siteId}
    />
  </Protected>
</MainLayout>

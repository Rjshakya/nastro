{
  "name": "server",
  "type": "module",
  "exports": {
    "./hc": {
      "default": "./dist/hc.js",
      "types": "./dist/hc.d.ts",
      "import": "./dist/hc.js"
    },
    "./domain": {
      "default": "./dist/domain.js",
      "types": "./dist/domain.d.ts",
      "import": "./dist/hc.js"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "secrets": "wrangler secret bulk .env.production",
    "build": "tsc",
    "lint": "oxlint --config oxlint.config.ts",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@hono/zod-validator": "^0.7.6",
    "@notionhq/client": "^5.11.0",
    "better-auth": "^1.4.19",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "effect": "4.0.0-beta.14",
    "hono": "^4.12.2",
    "hono-rate-limiter": "^0.5.3",
    "nanoid": "^5.1.6",
    "notion-client": "^7.8.2",
    "pg": "^8.18.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@effect/language-service": "^0.80.0",
    "@types/node": "^25.3.1",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "notion-types": "^7.8.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.21.0",
    "wrangler": "^4.4.0"
  }
}
